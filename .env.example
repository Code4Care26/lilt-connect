# Root .env — credenziali del PostgreSQL locale di sviluppo (docker-compose.yml).
#
# COME USARLO
#   cp .env.example .env      # poi, se vuoi, cambia i valori
# docker compose legge automaticamente questo .env. Senza .env il compose usa
# comunque i default "hackathron" (vedi ${VAR:-hackathron} in docker-compose.yml),
# quindi questo file è opzionale per far girare il progetto in locale.
#
# NOTA: questi sono SOLO i parametri del container Postgres locale. Rails si
# connette con i default in backend/config/database.yml: se cambi user/password
# qui, allinea anche backend/config/database.yml (o le sue env) altrimenti il
# backend non si connette.
#
# .env è gitignored; QUESTO file (.env.example) è versionato e NON deve mai
# contenere credenziali reali.

POSTGRES_USER=hackathron
POSTGRES_PASSWORD=hackathron
POSTGRES_DB=hackathron_development
