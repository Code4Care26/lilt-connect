# kapsule/.env.example — template dei segreti di deploy.
#
# COME USARLO
#   cp kapsule/.env.example kapsule/.env      # poi riempi i valori reali
#   chmod 600 kapsule/.env                     # leggibile solo da te
# Da quel momento ogni ./0N-*.sh lo carica da solo (lo sorgenta config.sh):
# niente più `export ...` a mano a ogni shell. kapsule/.env è gitignored;
# QUESTO file (.env.example) è versionato e NON deve contenere valori reali.
#
# Precedenza: questo file è la FONTE DI VERITÀ per i segreti. I knob di config
# (REGION, TAG, NODE_TYPE, ...) NON stanno qui e restano sovrascrivibili al
# volo da env (es. TAG=v5 ./05-deploy.sh).
#
# Persistenza/team: per non perderli al reset della macchina, conserva questi
# valori nel secret manager del team (questo file resta solo una copia locale).
#
# ─────────────────────────────────────────────────────────────────────────
# COSA RESTA PER IL PROSSIMO DEPLOY (azione tua, niente codice):
#   1. Generare UNA VOLTA il keypair VAPID e conservarlo nel secret manager
#      del team. Comando nel commento in testa a kapsule/04-secrets.sh:
#        cd backend && bundle exec ruby -e \
#          'require "web-push"; k=WebPush.generate_key; \
#           puts "VAPID_PUBLIC_KEY=#{k.public_key}"; \
#           puts "VAPID_PRIVATE_KEY=#{k.private_key}"'
#   2. Mettere VAPID_PUBLIC_KEY/VAPID_PRIVATE_KEY qui sotto (o esportarle)
#      PRIMA di ./04-secrets.sh, così finiscono nel Secret lilt-secrets.
#   3. Rebuild frontend per il nuovo sw.js:
#        ./03-build-push.sh <tag> && ./07-aggiorna.sh frontend <tag>
#   4. Verifica E2E del push su device reale (ultimo step del piano, ancora [ ]).
# ─────────────────────────────────────────────────────────────────────────

# ---- Datastore gestiti (password scelte alla creazione in 02-crea-db.sh) ----
export PG_PASSWORD=''
export REDIS_PASSWORD=''

# ---- Secret condiviso Rails <-> gosse (stesso valore da entrambi i lati) ----
export SSE_PUBLISH_SECRET=''

# ---- Web Push (VAPID) — keypair STABILE, vedi checklist sopra ----
# Rigenerarlo invalida tutte le subscription già salvate nei browser.
export VAPID_PUBLIC_KEY=''
export VAPID_PRIVATE_KEY=''
# Opzionale: identifica chi invia presso i push service. Se vuoto, 04-secrets.sh
# usa mailto:$ACME_EMAIL; il backend ripiega su mailto:noreply@lilt-connect.local.
export VAPID_SUBJECT=''

# ---- Rails master key (di norma NON serve qui) ----
# 04-secrets.sh la legge da backend/config/master.key se non la esporti.
# export RAILS_MASTER_KEY=''
