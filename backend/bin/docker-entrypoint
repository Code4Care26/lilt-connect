#!/bin/bash -e

# Enable jemalloc for reduced memory usage and latency.
if [ -z "${LD_PRELOAD+x}" ]; then
    LD_PRELOAD=$(find /usr/lib -name libjemalloc.so.2 -print -quit)
    export LD_PRELOAD
fi

# If running the rails server then create or migrate existing database.
# On Kubernetes set SKIP_DB_PREPARE=1 on the app pods: schema changes run once in
# a dedicated migration Job (kapsule/k8s/migrate-job.yaml), so the N replicas
# don't race each other on db:prepare at boot.
if [ "${@: -2:1}" == "./bin/rails" ] && [ "${@: -1:1}" == "server" ] && [ -z "${SKIP_DB_PREPARE}" ]; then
  ./bin/rails db:prepare
fi

exec "${@}"
